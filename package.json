{
  "name": "ts-eslint-prettier-jest-minimal",
  "version": "1.0.0",
  "description": "TypeScript template with ESLint, Prettier and Jest",
  "main": "lib/index.js",
  "packageManager": "pnpm@10.29.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "dev": "tsc --watch",
    "build": "pnpm run clean && tsc -b",
    "clean": "rm -rf lib coverage",
    "analyze": "pnpm run lint:fix && pnpm run compile",
    "compile": "tsc --noEmit",
    "compile:watch": "tsc --noEmit --watch",
    "compile:build": "tsc -b",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint-staged": "lint-staged",
    "lint-staged:debug": "lint-staged --debug",
    "format": "prettier --config .prettierrc '**/*.+(ts|tsx)'",
    "format:check": "prettier --config .prettierrc '**/*.+(ts|tsx)' --check",
    "format:fix": "prettier --config .prettierrc '**/*.+(ts|tsx)' --write",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "validate": "pnpm run compile && pnpm run lint && pnpm run test",
    "upgrade": "ncu -i",
    "upgrade:all": "ncu -u"
  },
  "author": "Softwarecrafters.io",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "30.4.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "lint-staged": "17.0.7",
    "npm-check-updates": "22.2.3",
    "prettier": "3.8.3",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.+(ts|tsx)": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
